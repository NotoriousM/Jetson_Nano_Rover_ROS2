        iyz="-0.0026917"
        izz="0.0017571" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Bogie_R.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.74902 0.74902 0.74902 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Bogie_R.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="bogie_right_joint"
    type="fixed">
    <origin
      xyz="0 -0.0936 0.3"
      rpy="0 0 0" />
    <parent
      link="Rocker_R" />
    <child
      link="Bogie_R" />
    <axis
      xyz="0 0 0" />
  </joint>
  <link
    name="Rotate_R_REAR">
    <inertial>
      <origin
        xyz="-0.033142 -0.036679 0"
        rpy="0 0 0" />
      <mass
        value="0.25826" />
      <inertia
        ixx="0.00057506"
        ixy="-0.00027903"
        ixz="3.5512E-21"
        iyy="0.00053749"
        iyz="-7.5345E-20"
        izz="0.00088635" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Rotate_R_REAR.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.74902 0.74902 0.74902 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Rotate_R_REAR.STL" />
      </geometry>
    </collision>
  </link>

  <!-- Заднее правое рулевое -->
  <joint name="rotate_right_rear_joint" type="revolute">
    <origin xyz="0.0697 -0.02925 0.2" rpy="0 0 0" />
    <parent link="Bogie_R" />
    <child link="Rotate_R_REAR" />
    <axis xyz="0 1 0" />
    <limit lower="-0.7" upper="0.7" effort="10.0" velocity="1.0"/>
  </joint>
  <link
    name="Wheel_R_REAR">
    <inertial>
      <origin
        xyz="-0.0009535 0 0"
        rpy="0 0 0" />
      <mass
        value="2.4144" />
      <inertia
        ixx="0.011293"
        ixy="-3.4168E-18"
        ixz="7.9905E-19"
        iyy="0.0070125"
        iyz="1.6805E-18"
        izz="0.0070129" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Wheel_R_REAR.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.74902 0.74902 0.74902 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Wheel_R_REAR.STL" />
      </geometry>
    </collision>
  </link>
  <!-- Правое заднее колесо -->
  <joint name="wheel_right_rear_joint" type="continuous">
    <origin xyz="0.00530000000000003 -0.1359 0" 
            rpy="-0.0246758236588165 0 0" />
    <parent link="Rotate_R_REAR" />
    <child link="Wheel_R_REAR" />
    <axis xyz="1 0 0" />
  </joint>
  <link
    name="Wheel_R_MIDDLE">
    <inertial>
      <origin
        xyz="-0.0009535 -5.5511E-17 2.7756E-17"
        rpy="0 0 0" />
      <mass
        value="2.4144" />
      <inertia
        ixx="0.011293"
        ixy="1.2851E-18"
        ixz="-3.8426E-19"
        iyy="0.0070125"
        iyz="-1.301E-18"
        izz="0.0070129" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Wheel_R_MIDDLE.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.74902 0.74902 0.74902 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://rover_description/meshes/Wheel_R_MIDDLE.STL" />
      </geometry>
    </collision>
  </link>
  <!-- Правое среднее колесо (неповоротное) -->
  <joint name="wheel_right_middle_joint" type="continuous">
    <origin xyz="0.075 -0.1659 -0.2"
            rpy="-2.58022563369304 0 0" />
    <parent link="Bogie_R" />
    <child link="Wheel_R_MIDDLE" />
    <axis xyz="1 0 0" />
  </joint>

  <!-- ============================================================
       ДОБАВЛЕНО: base_footprint (строки 684-692 — вставка перед </robot>)
       ============================================================ -->
  <link name="base_footprint">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.15" rpy="0 0 -1.5708"/>
    <parent link="base_footprint"/>
    <child  link="base_link"/>
  </joint>

  <!-- ДОБАВЛЕНО: подключение Gazebo-плагинов -->
  <xacro:include filename="$(find rover_description)/urdf/gazebo_plugins.xacro"/>

</robot>
